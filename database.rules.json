{
  "rules": {
    ".read": false,
    ".write": false,
    "teachers": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      },
      ".read": "auth != null" 
    },
    "students": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      },
      ".read": "auth != null"
    },
    "templates": {
      "$teacherUid": {
        ".read": "auth != null && auth.uid == $teacherUid",
        ".write": "auth != null && auth.uid == $teacherUid"
      }
    },
    "sessions": {
      ".read": true,
      "$sessionId": {
        ".read": true,
        ".write": "auth != null && data.child('teacherId').val() == auth.uid || !data.exists()",
        "participants": {
          "$participantId": {
            ".write": "auth == null || auth.uid == $participantId || !data.exists()"
          }
        }
      }
    },
    "responses": {
      "$sessionId": {
        ".read": "auth != null",
        "$responseId": {
          ".write": "true"
        }
      }
    }
  }
}
