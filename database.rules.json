{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$uid": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
      }
    },
    "teachers": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      },
      ".read": "auth != null" 
    },
    "students": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      },
      ".read": "auth != null"
    },
    "templates": {
      "$teacherUid": {
        ".read": "auth != null && auth.uid == $teacherUid",
        ".write": "auth != null && auth.uid == $teacherUid"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')"
      }
    },
    "roleOptions": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
    },
    "adminRoleChanges": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'",
      "$auditId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
      }
    },
    "activityLogs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'teacher'",
      "$logId": {
        ".write": "auth != null",
        ".validate": "!data.exists()"
      }
    },
    "sessions": {
      ".read": true,
      "$sessionId": {
        ".read": true,
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'teacher' || auth.uid == data.child('teacherId').val() || !data.exists())",
        "participants": {
          "$participantId": {
            ".write": "auth == null || auth.uid == $participantId || !data.exists()"
          }
        }
      }
    },
    "responses": {
      "$sessionId": {
        ".read": "auth != null",
        "$responseId": {
          ".write": "true"
        }
      }
    }
  }
}
